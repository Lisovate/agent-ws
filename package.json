{
  "bin" : {
    "agent-ws" : "dist/cli.js"
  },
  "bugs" : {
    "url" : "https://github.com/Lisovate/agent-ws/issues"
  },
  "dependencies" : {
    "commander" : "^14.0.3",
    "pino" : "^10.3.1",
    "pino-pretty" : "^13.0.0",
    "ws" : "^8.16.0"
  },
  "description" : "WebSocket bridge for CLI AI agents — stream Claude and Codex CLI responses over WebSocket",
  "devDependencies" : {
    "@types/node" : "^25.2.2",
    "@types/ws" : "^8.5.0",
    "esbuild" : "^0.27.3",
    "tsx" : "^4.21.0",
    "typescript" : "^5.7.0",
    "vitest" : "^4.0.18"
  },
  "engines" : {
    "node" : ">=20.0.0"
  },
  "files" : [
    "dist/",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "homepage" : "https://github.com/Lisovate/agent-ws#readme",
  "keywords" : [
    "claude",
    "codex",
    "ai",
    "cli",
    "agent",
    "bridge",
    "claude-code",
    "websocket",
    "streaming"
  ],
  "license" : "MIT",
  "main" : "dist/index.js",
  "name" : "agent-ws",
  "overrides" : {
    "picomatch" : "4.0.4"
  },
  "repository" : {
    "type" : "git",
    "url" : "git+https://github.com/Lisovate/agent-ws.git"
  },
  "scripts" : {
    "build" : "node build.js",
    "clean" : "rm -rf dist *.tsbuildinfo",
    "dev" : "tsx watch src/cli.ts",
    "prepublishOnly" : "npm run clean && npm run build && npm run typecheck && npm test",
    "start" : "node dist/cli.js",
    "test" : "vitest run",
    "test:watch" : "vitest",
    "typecheck" : "tsc --noEmit"
  },
  "type" : "module",
  "version" : "1.0.5"
}
